# ========================
# App
# ========================
NODE_ENV=development
PORT=3000
APP_NAME=Galangan Rizal API

# ========================
# Database (Lokal)
# ========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=galangan_rizal_db
DB_USER=root
DB_PASSWORD=

# ========================
# JWT
# ========================
JWT_SECRET=ganti_dengan_secret_key_yang_panjang_dan_acak
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=ganti_dengan_refresh_secret_yang_berbeda
JWT_REFRESH_EXPIRES_IN=7d

# ========================
# CORS
# ========================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ========================
# Upload
# ========================
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
